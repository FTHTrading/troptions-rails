{
  "name": "Troptions Rails - Professional Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esbenp.prettier-vscode",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "postCreateCommand": "chmod +x activate.sh && echo 'Troptions Rails dev environment ready. Run ./activate.sh'",
  "forwardPorts": [5000, 4020, 7332],
  "portsAttributes": {
    "5000": { "label": "Troptions Browser / nano-bana" },
    "4020": { "label": "x402 Pay Facilitator" }
  }
}
