# TROPTIONS Phase Execution Environment Template
# Copy to .env.phase and fill real values (never commit secrets)
# Used by phase-execute.ps1 and orchestrator phase runners

FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
# PRIVATE_KEY=0x...   # Test only, never mainnet
SECURITY_COUNCIL=0xYourCouncilAddress

# For CCIP etc.
INITIAL_CCIP_ROUTER=0x...

# Cloudflare / Web3 (for proofs)
CLOUDFLARE_API_TOKEN=your_token_here
CLOUDFLARE_ACCOUNT_ID=07bcc4a189ef176261b818409c95891f

# IPFS for proofs (optional live)
IPFS_API_KEY=your_pinata_or_equiv
IPFS_GATEWAY=https://gateway.pinata.cloud

# Local ports (from register)
APOSTLE_PORT=7332
UNY_PORT=4030
X402_PORT=4020

# Phase specific
PHASE_TARGET=0
MODE=simulate